<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#181D1F"
    tools:context=".day03_facebook_screen_ui.MainDay3Activity">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="335dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/imgCover"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:contentDescription="@string/Description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/cover_photo_d3"
                    android:background="@drawable/bg_cover_round_d3"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/bg_cover_overlay_d3"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="58dp"
                    android:gravity="center"
                    android:text="@string/menuIcon"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp" />

                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="58dp"
                    android:layout_marginEnd="105dp"
                    android:gravity="center"
                    android:text="@string/editPen"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp" />

                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="58dp"
                    android:layout_marginEnd="62dp"
                    android:gravity="center"
                    android:text="@string/other"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="58dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:text="@string/search"
                    android:textColor="#FFFFFF"
                    android:textSize="38sp" />

                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="155dp"
                    android:layout_marginEnd="20dp"
                    android:gravity="center"
                    android:text="@string/camera"
                    android:textSize="19sp"
                    android:background="@drawable/bg_dark_circle_d3" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:background="@drawable/bg_profile_panel_d3"
                    android:paddingStart="135dp"
                    android:paddingTop="40dp"
                    android:paddingEnd="20dp"
                    android:elevation="6dp">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fbName"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="25sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/fbBio"
                        android:textColor="#E0E0E0"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:text="@string/otherBio"
                        android:textColor="#D5D5D5"
                        android:textSize="15sp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="142dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_d3"
                    android:background="@drawable/bg_avatar_circle_d3"
                    android:padding="4dp"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:elevation="10dp" />

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="95dp"
                    android:layout_marginTop="215dp"
                    android:gravity="center"
                    android:text="@string/camera"
                    android:textSize="18sp"
                    android:background="@drawable/bg_dark_circle_d3"
                    android:elevation="12dp" />

            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/love"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/InfoFB"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/Dashboard"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:background="@drawable/bg_blue_button_d3" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/reel"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:background="@drawable/bg_gray_button_d3" />

            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingBottom="30dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="@string/all"
                        android:textColor="#D9ECFF"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:background="@drawable/bg_tab_selected_d3" />

                    <TextView
                        android:layout_width="95dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="@string/Reel"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="@string/Tag"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="105dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="@string/Events"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="18sp" />

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PersonalDetails"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adress"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="19sp"
                android:paddingStart="30dp"
                android:paddingBottom="26dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/HomeAdress"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="19sp"
                android:paddingStart="30dp"
                android:paddingBottom="26dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dB"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="19sp"
                android:paddingStart="30dp"
                android:paddingBottom="22dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/MoreDetail"
                android:textColor="#A9A9A9"
                android:textStyle="bold"
                android:textSize="17sp"
                android:paddingBottom="38dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/edu"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:src="@drawable/school_logo_d3"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle_d3"
                    android:padding="3dp"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="18dp"
                    android:text="@string/university"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#181D1F"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tabHome"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tabReel"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tabMarket"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tabGame"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/noty"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tabProfile"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>