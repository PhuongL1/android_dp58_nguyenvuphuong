<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".day05_pinterest_ui_demo.MainDay5Activity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/img_logo_pinterest"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/logo_pinterest_d5" />

            <TextView
                android:id="@+id/tv_logo_pinterest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/logo_pinterest"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/color_pinterest" />

        </LinearLayout>

        <ImageView
            android:id="@+id/iv_btn_add"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/btn_add_d5" />

        <ImageView
            android:id="@+id/iv_btn_search"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:padding="4dp"
            android:src="@drawable/btn_search_d5" />

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_tabs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tab_for_you"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="For You"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_tab_selected_d5" />

            <TextView
                android:id="@+id/tab_popular"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Popular"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_tab_unselected_d5" />

            <TextView
                android:id="@+id/tab_design"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Design"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_tab_unselected_d5" />

            <TextView
                android:id="@+id/tab_technology"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Technology"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_tab_unselected_d5" />

            <TextView
                android:id="@+id/tab_food"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Food"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_tab_unselected_d5" />

            <TextView
                android:id="@+id/tab_travel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Travel"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_tab_unselected_d5" />

        </LinearLayout>

    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_pinterest_reel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/white"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/img_btn_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/btn_home_d5" />

        <ImageView
            android:id="@+id/img_btn_message"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/btn_message_d5" />

        <ImageView
            android:id="@+id/img_btn_notification"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/btn_notification_d5" />

        <ImageView
            android:id="@+id/img_btn_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/btn_profile_d5" />

    </LinearLayout>

</LinearLayout>