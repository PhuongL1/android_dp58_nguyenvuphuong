<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_cart_item_d6"
    android:elevation="3dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/iv_cart_coffee"
        android:layout_width="78dp"
        android:layout_height="90dp"
        android:background="#FAFAFA"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/mixed_black_coffee_d6" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cart_coffee_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cart_coffee_name"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_cart_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/rating"
            android:textColor="@color/black"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_cart_price"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom"
            android:text="@string/price"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="110dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_quantity_d6"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/tv_minus_cart"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="11dp"
            android:src="@drawable/btn_minus"/>

        <TextView
            android:id="@+id/tv_quantity_cart"
            android:layout_width="34dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_quantity_number_d6"
            android:gravity="center"
            android:text="@string/quantitycart"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/tv_plus_cart"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="11dp"
            android:src="@drawable/btn_plus" />

    </LinearLayout>

</LinearLayout>